# --- TELEGRAM BOT CONFIGURATION ---
# Replace the placeholders below with your actual credentials.

# Your Telegram Bot Token obtained from @BotFather (e.g. 1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Your Channel Username with @ prefix (e.g. @mydealalerts) or Channel ID (e.g. -100123456789)
TELEGRAM_CHANNEL_USERNAME=@YOUR_CHANNEL_USERNAME_HERE

# The real Myntra product URL you want the bot to scrape
MYNTRA_PRODUCT_URL=https://www.myntra.com/1364628

# --- EARNKARO AFFILIATE AUTOMATION ---
# Fill in your EarnKaro mobile or email to automatically generate affiliate links.
# If left blank, the bot will automatically fall back to posting the original e-commerce links.
EARNKARO_MOBILE_OR_EMAIL=YOUR_EARNKARO_MOBILE_OR_EMAIL_HERE

# Whether to automatically convert product URLs to affiliate links (True/False)
USE_AFFILIATE_LINKS=True

# If affiliate conversion fails, whether to fall back to the original URL (True) or skip the deal completely (False)
AFFILIATE_FALLBACK_TO_ORIGINAL=False

# Limit on the maximum number of affiliate links converted per scan cycle
MAX_AFFILIATE_GENERATIONS_PER_SCAN=3

# --- PRODUCTION-SAFE QUALITY FILTERS ---
# Minimum discount percentage to qualify as a deal (e.g. 80)
DISCOUNT_THRESHOLD=80

# Minimum price in INR to qualify a deal (prevents extremely cheap/low quality items)
MIN_PRICE=200

# Maximum price in INR to qualify a deal (prevents extremely expensive luxury items)
MAX_PRICE=5000
